# Endpoint de leads consumido DESDE EL NAVEGADOR (FormSubmit está detrás de
# Cloudflare y bloquea envíos server-side, por eso el formulario envía
# directo desde el navegador). Opcional: por defecto usa el buzón de MyFix.
# NEXT_PUBLIC_LEADS_ENDPOINT=https://formsubmit.co/ajax/myfixperu@gmail.com

# URL pública del sitio (para metadata, sitemap y robots). Obligatoria en producción.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
